{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true
  },
  "include": [".astro/types.d.ts", "src/**/*", "scripts/**/*", "astro.config.mjs", "vitest.config.ts"]
}
