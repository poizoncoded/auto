{
  "name": "auto-spendings",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "mprocs --config mprocs.yaml",
    "dev:https": "mprocs --config mprocs.https.yaml",
    "dev:tunnel": "node scripts/dev-tunnel.ts",
    "dev:rebuild": "node scripts/rebuild-astro.ts && node ./node_modules/astro/bin/astro.mjs sync",
    "predev:fe": "npm run dev:rebuild",
    "dev:fe": "node --env-file-if-exists=.env ./node_modules/astro/bin/astro.mjs dev --host 0.0.0.0 --port 4321 --force",
    "dev:lan": "npm run dev:fe",
    "predev:lan:alt": "npm run dev:rebuild",
    "dev:lan:alt": "node --env-file-if-exists=.env ./node_modules/astro/bin/astro.mjs dev --host 0.0.0.0 --port 4322 --force",
    "dev:be": "npm run db:up && npm run db:migrate && docker compose logs --follow --tail 50 db",
    "start": "node --env-file-if-exists=.env ./dist/server/entry.mjs",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "test": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run",
    "test:integration": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:watch": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "astro check",
    "db:up": "docker compose up --detach --wait db",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.ts",
    "db:revert": "node --env-file-if-exists=.env scripts/revert-migration.ts"
  },
  "dependencies": {
    "@astrojs/node": "11.0.2",
    "@astrojs/react": "6.0.1",
    "astro": "7.1.3",
    "jsqr": "1.4.0",
    "lucide-react": "1.25.0",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typeorm": "1.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "mprocs": "0.9.6",
    "qrcode": "1.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
